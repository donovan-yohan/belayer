FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    tmux git curl jq ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Create belayer user
RUN useradd -m -s /bin/bash -u 1000 belayer

# Install belayer CLI (built externally, copied in)
COPY belayer /usr/local/bin/belayer
RUN chmod +x /usr/local/bin/belayer

WORKDIR /workspace

# Run as belayer user by default
USER belayer

# tmux as the execution substrate — agent shell starts here
ENTRYPOINT ["tmux", "new-session", "-s", "agent"]
